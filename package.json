{
  "name": "fastify-boilerplate",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "local": "nodemon -r tsconfig-paths/register src/api/api.ts",
    "local:env": "docker compose -f docker-compose.local.yml up",
    "build": "rm -R -f dist && tsc -p tsconfig.build.json",
    "production": "TS_NODE_BASEURL=dist node -r tsconfig-paths/register dist/src/api/api.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "db:migration:run": "drizzle-kit migrate",
    "db:migration:generate": "drizzle-kit generate",
    "db:migration:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@sendgrid/mail": "^8.1.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.21.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0"
    }
  },
  "packageManager": "pnpm@11.8.0"
