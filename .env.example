# Validated by src/types/EnvSchema.ts at startup — server won't boot if missing/invalid

# Optional timezone
TZ=UTC

# local | staging | production
NODE_ENV=local

# Server
PORT=3000
HOST=0.0.0.0

# Postgres
PGHOST=localhost
PGPORT=5432
PGUSERNAME=postgres
PGPASSWORD=postgres
PGDATABASE=app

# Swagger basic auth (PGPASSWORD min length 10)
SWAGGER_USER=admin
SWAGGER_PWD=changeme123
